# Crown Roofing Staff Playbook — Required Environment Variables
#
# Copy this file to .env and fill in the values to run locally.
# DO NOT commit .env — it is gitignored.
#
# For collaborators: the fastest way to get real values is to be added to the
# Vercel team, then run:   vercel link && vercel env pull .env

# GoHighLevel CRM integration — used by api/reports.js
CROWN_GHL_API_KEY=
CROWN_GHL_LOCATION_ID=
